---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "เกี่ยวกับเจ - ผู้เชี่ยวชาญด้าน AI และ Workflow Automation",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			สวัสดีครับ ผมเจ — จบวิศวกรรมคอมพิวเตอร์ เกียรตินิยมอันดับ 1 จากมหาวิทยาลัยเกษตรศาสตร์<br/>
			เป็น Ex-ML Engineering ที่ Agoda และอยู่ในวงการ AI มาเกือบ 4 ปีแล้วครับ
		</p>
		<p>
			ในยุคที่ข้อมูล AI ท่วมหัว หาของจริงยาก หลอกลวงเยอะ —<br/>
			ผมเลยทำ content นี้ขึ้นมาเพื่อคัดกรองให้ครับ<br/>
			ไม่ใช่แค่ตามเทรนด์ แต่เป็น Use Case จริง ที่ Research มาแล้วว่าใช้ได้<br/>
			เพื่อให้คุณ Transform การทำงานได้จริง — ทั้งในองค์กรและในชีวิตส่วนตัว
		</p>
		<p>ถ้าคุณเป็นคนที่...</p>
		<ul class="list-inside list-disc" role="list">
			<li>รู้สึกว่าวันหนึ่งหมดไปกับงาน Manual ที่ไม่ควรทำเอง</li>
			<li>อยากใช้ AI แต่ไม่รู้จะเริ่มตรงไหนที่มัน "เวิร์ก" จริงๆ</li>
			<li>เบื่อ Content AI ที่พูดแต่ทฤษฎี ไม่มี Use Case จริงให้จับต้อง</li>
			<li>อยากขยายธุรกิจหรืองานโดยไม่ต้องเพิ่มชั่วโมงทำงาน</li>
		</ul>
		<p>เรามาร่วมเส้นทางไปด้วยกันครับ ยินดีที่ได้รู้จัก 🤝</p>
	</div>
</PageLayout>
